rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function profile() { return get(/databases/$(database)/documents/utenti/$(request.auth.uid)).data; }
    function enabled() { return signedIn() && profile().abilitato == true; }
    function role() { return profile().ruolo; }
    function isDirectAdminEmail() { return signedIn() && request.auth.token.email == 'ionut29019@gmail.com'; }
    function isAdmin() { return (enabled() && role() == 'admin') || isDirectAdminEmail(); }
    function isTechnician() { return enabled() && role() == 'tecnico'; }
    function isOperator() { return enabled() && role() == 'operatore'; }
    function sameCompany() { return isDirectAdminEmail() || (enabled() && resource.data.aziendaId == profile().aziendaId); }
    function incomingSameCompany() { return isDirectAdminEmail() || (enabled() && request.resource.data.aziendaId == profile().aziendaId); }
    function ownTechnicianData() { return isTechnician() && resource.data.tecnicoId == request.auth.uid; }
    function ownOperatorData() { return isOperator() && resource.data.operatoreId == request.auth.uid; }
    function assignedOperatorRoute() {
      return isOperator()
        && request.auth.uid in resource.data.operatoriAssegnati
        && resource.data.tecnicoId == profile().tecnicoId;
    }

    match /utenti/{uid} {
      allow read: if signedIn() && (uid == request.auth.uid || isAdmin() || ownTechnicianData());
      allow create: if signedIn()
        && uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && (
          (request.resource.data.ruolo == 'operatore' && request.resource.data.abilitato == false)
          || (isDirectAdminEmail() && request.resource.data.ruolo == 'admin' && request.resource.data.abilitato == true)
        );
      allow update: if isAdmin() || (uid == request.auth.uid && isDirectAdminEmail());
    }

    match /aziende/{aziendaId} {
      allow read, write: if isAdmin();
    }

    match /percorsi/{percorsoId} {
      allow read: if sameCompany() && (isAdmin() || ownTechnicianData() || assignedOperatorRoute());
      allow create, update, delete: if incomingSameCompany() && (isAdmin() || (isTechnician() && request.resource.data.tecnicoId == request.auth.uid));
    }

    match /tracceGPS/{tracciaId} {
      allow read: if sameCompany() && (isAdmin() || ownTechnicianData() || ownOperatorData());
      allow create, update: if incomingSameCompany()
        && (isAdmin()
          || (isTechnician() && request.resource.data.tecnicoId == request.auth.uid)
          || (isOperator() && request.resource.data.operatoreId == request.auth.uid && request.resource.data.tecnicoId == profile().tecnicoId));
    }

    match /fotoServizio/{fotoId} {
      allow read: if sameCompany() && (isAdmin() || ownTechnicianData() || ownOperatorData());
      allow create, update: if incomingSameCompany()
        && (isAdmin()
          || (isTechnician() && request.resource.data.tecnicoId == request.auth.uid)
          || (isOperator() && request.resource.data.operatoreId == request.auth.uid && request.resource.data.tecnicoId == profile().tecnicoId));
    }
  }
}
