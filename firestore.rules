rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function profile() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function enabled() { return signedIn() && profile().stato == 'abilitato'; }
    function role() { return profile().ruolo; }
    function aziendaId() { return profile().aziendaId; }
    function tecnicoId() { return profile().tecnicoId; }
    function isAdmin() { return enabled() && role() == 'admin'; }
    function isTecnico() { return enabled() && role() == 'tecnico'; }
    function isOperatore() { return enabled() && role() == 'operatore'; }
    function sameAzienda(cid) { return enabled() && aziendaId() == cid; }
    function validUser() {
      return request.resource.data.keys().hasOnly(['uid', 'nome', 'email', 'ruolo', 'aziendaId', 'tecnicoId', 'stato', 'createdAt'])
        && request.resource.data.uid is string
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.ruolo in ['admin', 'tecnico', 'operatore']
        && request.resource.data.stato in ['in_attesa', 'abilitato', 'bloccato'];
    }

    match /users/{uid} {
      allow read: if signedIn() && (uid == request.auth.uid || (sameAzienda(resource.data.aziendaId) && (isAdmin() || (isTecnico() && resource.data.tecnicoId == request.auth.uid))));
      allow create: if signedIn() && uid == request.auth.uid && validUser() && request.resource.data.stato == 'in_attesa';
      allow update: if isAdmin() && resource.data.aziendaId == aziendaId() && request.resource.data.aziendaId == aziendaId();
      allow delete: if isAdmin() && resource.data.aziendaId == aziendaId();
    }

    match /aziende/{cid} {
      allow read: if sameAzienda(cid);
      allow create, update, delete: if isAdmin() && aziendaId() == cid;

      match /percorsi/{percorsoId} {
        allow read: if sameAzienda(cid) && (isAdmin() || (isTecnico() && resource.data.tecnicoId == request.auth.uid) || (isOperatore() && resource.data.tecnicoId == tecnicoId()));
        allow create, update, delete: if sameAzienda(cid) && (isAdmin() || (isTecnico() && request.resource.data.tecnicoId == request.auth.uid));
      }

      match /progetti/{progettoId} {
        allow read: if sameAzienda(cid) && (isAdmin() || (isTecnico() && resource.data.tecnicoId == request.auth.uid) || (isOperatore() && resource.data.tecnicoId == tecnicoId()));
        allow create, update, delete: if sameAzienda(cid) && (isAdmin() || (isTecnico() && request.resource.data.tecnicoId == request.auth.uid));
      }

      match /operatori/{operatoreId} {
        allow read: if sameAzienda(cid) && (isAdmin() || (isTecnico() && resource.data.tecnicoId == request.auth.uid) || (isOperatore() && resource.data.uid == request.auth.uid));
        allow create: if signedIn() && operatoreId == request.auth.uid && request.resource.data.uid == request.auth.uid && request.resource.data.stato == 'in_attesa';
        allow update, delete: if sameAzienda(cid) && (isAdmin() || (isTecnico() && resource.data.tecnicoId == request.auth.uid));
      }

      match /serviziNeve/{servizioId} {
        allow read: if sameAzienda(cid) && (isAdmin() || (isTecnico() && resource.data.tecnicoId == request.auth.uid) || (isOperatore() && resource.data.operatoreId == request.auth.uid));
        allow create, update: if sameAzienda(cid) && isOperatore() && request.resource.data.operatoreId == request.auth.uid && request.resource.data.tecnicoId == tecnicoId();
      }

      match /posizioniLive/{operatoreId} {
        allow read: if sameAzienda(cid) && (isAdmin() || (isTecnico() && resource.data.tecnicoId == request.auth.uid) || (isOperatore() && operatoreId == request.auth.uid));
        allow create, update: if sameAzienda(cid) && isOperatore() && operatoreId == request.auth.uid && request.resource.data.tecnicoId == tecnicoId();
      }
    }
  }
}
